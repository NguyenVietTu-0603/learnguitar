# Flask AI - Guitar Tablature Detection
# Copy this file to `.env` and fill in real values for local dev.
# On Railway, set these same values in the service's "Variables" tab.

# --- Server ---
PORT=5001
FLASK_DEBUG=false
APP_NAME=Flask AI API
API_PREFIX=/api

# --- Model ---
# Default: looks for ./best.pt in this folder.
# On Railway, override with an absolute path if you upload the model via a
# different mechanism (volume, S3, etc.). For LFS-tracked models, this default
# is fine since Git LFS pulls the real file at deploy time.
MODEL_PATH=./best.pt

# --- Model download (fallback) ---
# If the local model file is missing or a Git LFS pointer, the app downloads
# from this URL. Set to a public, stable link (e.g. a GitHub Release asset).
# Default points to a release in the learnguitar repo; override here or on
# Railway's "Variables" tab if you re-host the file elsewhere.
MODEL_DOWNLOAD_URL=https://github.com/NguyenVietTu-0603/learnguitar/releases/download/v1.0.0/best.pt

# --- CORS ---
# Comma-separated list of allowed origins.
# In production, set this to the deployed frontend URL(s).
# Example: CORS_ORIGINS=https://learn-guitar-frontend.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:5174
