# Workspace-level ignores
# (project-specific .gitignore files are inside each subfolder)

# Python virtual envs created at workspace root
.venv/
venv/
env/

# Root-level Node leftovers (likely a stray scratch package.json using Prisma)
node_modules/
package.json
package-lock.json

# Common IDE / OS junk (in case the editor saves them at workspace root)
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo

# Global log files
*.log

# Cursor agent caches
.cursor/

# PowerShell transcript files
*.transcript.txt

# Temporary scratch files
tmp/
temp/
scratch/
abc.txt

# Local test reports and outputs (HTML/TXT generated by the test harness)
TEST_BACKEND_OUTPUT.txt
TEST_BACKEND_REPORT.html
TEST_FLASK_OUTPUT.txt
TEST_FLASK_REPORT.html
TEST_FRONTEND_OUTPUT.txt
TEST_FRONTEND_REPORT.html
TEST_REPORT.html
