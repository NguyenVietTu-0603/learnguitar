{
  "$schema": "https://railpack.com/schema.json",
  "provider": "node",
  "build": {
    "commands": {
      "build": "npm install --omit=dev"
    }
  },
  "deploy": {
    "startCommand": "node src/app.js",
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 100,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
